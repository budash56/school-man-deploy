# Production deployment identity
COMPOSE_PROJECT_NAME=school-man-production
DEPLOYMENT_NAME=school-man-production

# PostgreSQL container settings
POSTGRES_DB=schoolmg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Backend runtime settings
DATABASE_URL=postgres://postgres:change-me@db:5432/schoolmg
DB_MIGRATIONS_RUN=true
JWT_SECRET=replace-with-a-long-random-secret
BIND_ADDRESS=0.0.0.0
FRONT_PORT=8080
BACK_PORT=3000
VITE_ENABLE_TEST_FEATURES=false
SCANNER_BASE_URL=http://scanner:8010
SCANNER_TIMEOUT_MS=120000
SCHOOL_SCANNER_OCR_ENGINE=tesseract

# Email settings
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=SchoolMan
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_BULK_BATCH_SIZE=20
